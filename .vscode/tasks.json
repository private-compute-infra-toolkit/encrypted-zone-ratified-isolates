{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Generate rust-project.json",
      "type": "shell",
      "command": ".vscode/rust-project-generator.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "never",
        "panel": "dedicated"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
